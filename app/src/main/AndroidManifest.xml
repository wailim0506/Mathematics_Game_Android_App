        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ITP4501_Assignment"
        tools:targetApi="31">
        <service android:name=".BackgroundMusicService"/>
        <service android:name=".correctSoundEffectService"/>
        <service android:name=".wrongSoundEffectService"/>
