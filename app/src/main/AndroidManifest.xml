        <service android:name=".loseSoundEffectService"/>
        <service android:name=".knifeSoundEffectService"/>
        <activity
            android:name=".gameFinish"
            android:exported="false" />
        <activity
            android:name=".howToPlay"
            android:exported="false" />
        <activity
            android:name=".mainMenu"
            android:exported="false" />
        <activity
            android:name=".gamePlay"
            android:exported="false" />
        <activity
            android:name=".ranking"
            android:exported="false" />
        <activity
            android:name=".userRecord"
            android:exported="false" />
        <activity
            android:name=".Login"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>