<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/game_bg1"
    tools:context=".gameFinish">

    <ImageView
        android:layout_width="300dp"
        android:layout_height="67dp"
        android:layout_gravity="center"
        android:src="@drawable/title_game_finish"
        android:layout_marginTop="95dp"/>
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >
        <TableRow>
            <TextView
                android:id="@+id/gameFinish_count_textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CORRECT: 1, WRONG: 2"
                android:textSize="30sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_marginTop="150dp"
                android:fontFamily="@font/roboto_slab"/>
        </TableRow>
        <TableRow>
            <TextView
                android:id="@+id/gameFinish_result_textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="YOU"
                android:textSize="30sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/roboto_slab"/>
        </TableRow>
        <TableRow>
            <TextView
                android:id="@+id/gameFinish_time_textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Time: 100 seconds"
                android:textSize="30sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_marginTop="17dp"
                android:fontFamily="@font/roboto_slab"/>
        </TableRow>
    </TableLayout>
    <ImageView
        android:id="@+id/gameFinish_continue_button"
        android:layout_width="250dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:layout_marginTop="30dp"
        android:src="@drawable/button_continue"/>
    <ImageView
        android:id="@+id/gameFinish_main_menu_button"
        android:layout_width="250dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:src="@drawable/button_main_menu"/>
</LinearLayout>