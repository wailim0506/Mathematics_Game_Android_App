<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/game_bg1"
    tools:context=".howToPlay">

    <ImageView
        android:layout_width="350dp"
        android:layout_height="97dp"
        android:layout_gravity="center"
        android:src="@drawable/title_game_title"
        android:layout_marginTop="75dp"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/instruction"
        android:layout_marginTop="-130dp"/>

    <ImageView
        android:id="@+id/how_to_play_goBack_button"
        android:layout_width="290dp"
        android:layout_height="40dp"
        android:src="@drawable/button_go_back"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="-150dp"/>

</LinearLayout>